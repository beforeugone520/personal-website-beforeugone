# Network and storage. Keep the API on loopback; Caddy is the public listener.
LISTEN_ADDR=127.0.0.1:8787
DATABASE_PATH=/var/lib/beforeu-api/beforeu.db
CORS_ALLOWED_ORIGINS=https://beforeugone.com
REACTION_PAGE_KEYS=/posts/hello-world.html

# Generate both independently, for example with: openssl rand -hex 32
ADMIN_TOKEN=
ANONYMIZATION_SECRET=

# Required for public writes in production. The site key belongs in the static
# frontend; only the secret key belongs here. With no secret, reads stay up but
# public writes fail closed with 503.
TURNSTILE_SECRET=
TURNSTILE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
TURNSTILE_ALLOWED_HOSTNAMES=beforeugone.com

# Local static previews may bypass Turnstile only when STATIC_DIR is also set.
# Never enable this in production.
ALLOW_INSECURE_PUBLIC_WRITES=false

# Optional GitHub Ship Log ingestion. Leave both values empty to disable it.
# Repository example: beforeugone520/personal-website-beforeugone
GITHUB_WEBHOOK_SECRET=
GITHUB_ALLOWED_REPOSITORIES=

# GitHub activity is refreshed server-side and served from a last-good SQLite
# snapshot. With a token, the backend uses the official GraphQL API. Without one,
# it combines public repository metadata from GitHub REST with GitHub's public
# rolling contributions HTML. That HTML is an internal public web surface, so a
# parsing/upstream failure keeps the last-good snapshot instead of failing health.
# Tokenless attempts, including webhook wakeups, are kept at least two minutes apart.
# If a token is configured, use public-read-only permissions: do not grant classic
# `read:user`, `user`, or `repo` scopes, private-repository access, or fine-grained
# account permissions that can reveal non-public contributions. Never put the
# token in the static site or browser JavaScript.
GITHUB_USERNAME=beforeugone520
GITHUB_API_TOKEN=
GITHUB_REFRESH_INTERVAL=15m
GITHUB_REQUEST_TIMEOUT=10s

# Leave empty in production: the website stays on GitHub Pages. This is useful
# only when serving a local static fixture during development.
STATIC_DIR=

PUBLIC_WRITE_RATE_LIMIT=10
PUBLIC_WRITE_RATE_WINDOW=1m
SHUTDOWN_TIMEOUT=10s

# The supplied Caddy config overwrites X-BeforeU-Client-IP after validating the
# proxy chain. The API trusts it only from a loopback peer.
TRUST_PROXY_HEADERS=true
